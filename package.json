{
  "name": "vibe-admiral",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "engine"
  ],
  "scripts": {
    "dev": "node scripts/dev-runner.mjs",
    "dev:no-restart": "concurrently \"vite\" \"tsx watch engine/src/index.ts\"",
    "dev:frontend": "vite",
    "build": "tsc -b && vite build && npm run build --workspace=engine",
    "build:frontend": "tsc -b && vite build",
    "start": "ADMIRAL_ENV=production node engine/dist/index.js",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:engine": "vitest run --project engine",
    "test:ui": "playwright test --config playwright.ui.config.ts",
    "test:e2e": "playwright test --config playwright.e2e.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.8.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
