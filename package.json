{
  "name": "vibe-admiral",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "engine"
  ],
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch engine/src/index.ts\"",
    "dev:frontend": "vite",
