{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-tauri/HEAD/core/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capability with full permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "dialog:allow-open"
  ]
}
